cat << 'EOF' > .gitignore
# Environments
.venv/

# Python Cache
__pycache__/
*.pyc

# Build Artifacts
build/
*.pyd
*.so
*.dll
*.egg-info/
dist/

# Runtime config & State
policy.json
state.json

# Testing & coverage
.coverage
coverage/
htmlcov/
test_*.py

# Lint/type caches
.mypy_cache/
.ruff_cache/

# Editors
.vscode/
.idea/
EOF